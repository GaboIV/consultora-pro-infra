# =====================================================================
#  ConsultoraPro - Variables de entorno para el despliegue (servidor)
# =====================================================================
#
#  COMO USARLO:
#   - Este archivo es SOLO una plantilla. NO contiene secretos reales.
#   - En el SERVIDOR, copia este archivo a ".env" y rellena los valores:
#       cp .env.example .env && nano .env
#   - Tendras un ".env" distinto en el servidor de QA y en el de PROD
#     (o en el mismo servidor, en carpetas distintas).
#   - El archivo ".env" real NUNCA se sube a Git (esta en .gitignore).
#
#  Ver docs/05-secretos-y-conexiones.md para el detalle de seguridad.
# =====================================================================

# --- Identidad del stack (cambia entre qa y prod para no colisionar) ---
COMPOSE_PROJECT_NAME=consultorapro_qa     # consultorapro_prod en produccion

# --- Imagenes en GitHub Container Registry (GHCR) ---
# El owner va en minusculas. IMAGE_TAG decide que version se despliega:
#   qa   -> ultima imagen de la rama qa
#   prod -> ultima imagen de la rama main
BACKEND_IMAGE=ghcr.io/gaboiv/consultora-pro-backend
FRONTEND_IMAGE=ghcr.io/gaboiv/consultora-pro-frontend
IMAGE_TAG=qa                              # prod en produccion

# --- Puertos publicados en el host ---
FRONTEND_PORT=8080                        # http://servidor:8080
BACKEND_PORT=5000                         # http://servidor:5000 (API)

# --- Base de datos MySQL ---
MYSQL_ROOT_PASSWORD=cambia-esto-root-super-seguro
MYSQL_DATABASE=consultorapro
MYSQL_USER=consultorapro
MYSQL_PASSWORD=cambia-esto-user-super-seguro

# --- Backend (.NET) ---
ASPNETCORE_ENVIRONMENT=Production
JWT_KEY=cambia-esto-clave-jwt-min-32-caracteres-larga
JWT_ISSUER=ConsultoraPro
JWT_AUDIENCE=ConsultoraProApp
